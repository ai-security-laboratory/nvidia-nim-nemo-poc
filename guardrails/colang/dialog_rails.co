define user ask about order status
  "where is my order"
  "track my order"
  "what is the status of my order"
  "order status"
  "where is my package"

define bot request identity for order
  "To look up your order I need to verify your identity. Please provide your full name and order number (e.g. ORD-001)."

define flow order lookup
  user ask about order status
  bot request identity for order
